// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Session {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  durationMs   Int
  dataSource   String
  avgFocus     Float
  avgStress    Float
  avgCalmness  Float
}
